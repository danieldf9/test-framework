{
  "name": "@sentinel/core",
  "version": "0.1.0",
  "description": "Self-healing Playwright test framework core: intent-annotated fixture, tiered healing pipeline, SQLite state.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",

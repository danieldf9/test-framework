{
  "name": "@sentinel/server",
  "version": "0.1.0",
  "description": "Sentinel Studio server: local-first Fastify JSON API over the state DB, serving the web dashboard.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@sentinel/core": "workspace:*",
    "@sentinel/flow": "workspace:*",
    "@sentinel/ops": "workspace:*",
    "@sentinel/providers": "workspace:*",
    "@sentinel/report": "workspace:*",
    "@sentinel/web": "workspace:*",
    "@fastify/static": "^8.0.3",
    "@playwright/test": "^1.49.1",
    "fastify": "^5.2.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

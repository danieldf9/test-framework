{
  "name": "@sentinel/report",
  "version": "0.1.0",
  "description": "Static HTML report generator for Sentinel runs: results, heals with before/after screenshots, flake dashboard, LLM cost summary.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@sentinel/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
